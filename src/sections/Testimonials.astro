---
import Icon from '@components/Icon.astro';

type Props = { block: any };
const { block } = Astro.props;
const items = block?.items ?? [];
---

<section class="section bg-white">
  <div class="container-x">
    <div class="reveal mx-auto max-w-3xl text-center">
      {block?.eyebrow && <p class="eyebrow justify-center">{block.eyebrow}</p>}
      <h2 class="heading-section mt-4 text-balance">
        {block?.headingStart}
        {block?.headingAccent && <> <span class="text-gold-500">{block.headingAccent}</span></>}
      </h2>
    </div>

    <div class="mt-14 grid gap-6 lg:grid-cols-3">
      {
        items.map((t: any, i: number) => (
          <figure
            class="group relative flex flex-col rounded-2xl bg-white/70 ring-1 ring-navy-900/5 p-8 transition-all duration-500 hover:ring-navy-900/10 reveal"
            style={`transition-delay: ${i * 80}ms`}
          >
            <Icon name="quote" class="h-8 w-8 text-gold-500" />
            <blockquote class="mt-5 flex-1 font-serif text-lg italic leading-relaxed text-navy-900">
              "{t.quote}"
            </blockquote>
            <figcaption class="mt-6 border-t border-steel-100 pt-5">
              <p class="font-display text-sm font-bold tracking-tight">
                {t.author}
              </p>
              <p class="text-xs uppercase tracking-[0.15em] text-steel-500">
                {t.role}
              </p>
            </figcaption>
          </figure>
        ))
      }
    </div>
  </div>
</section>
