---
import Icon from '@components/Icon.astro';
import { partnerProducts, site } from '@data/site';
---

<section id="partners" class="section bg-white">
  <div class="container-x">
    <div class="reveal mx-auto max-w-3xl text-center">
      <p class="eyebrow justify-center">In partnership with</p>
      <h2 class="heading-section mt-4 text-balance">
        Exclusive representatives of
        <span class="text-gold-500">Style by Global.</span>
      </h2>
      <p class="lead mt-6">
        Through our partnership we deliver premium roller blinds, plantation
        shutters, motorized smart blinds and decorative window solutions to every project.
      </p>
    </div>

    <div class="mt-14 grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
      {
        partnerProducts.map((product, i) => (
          <article
            class="group relative reveal"
            style={`transition-delay: ${i * 60}ms`}
          >
            <div class="relative overflow-hidden rounded-xl bg-navy-50 ring-1 ring-navy-900/5 transition-all duration-500 group-hover:ring-navy-900/10">
              <div class="aspect-[4/5] overflow-hidden">
                <img
                  src={product.image}
                  alt={product.title}
                  loading="lazy"
                  class="h-full w-full object-cover transition-transform duration-[900ms] ease-out group-hover:scale-[1.08]"
                />
              </div>
              <div class="pointer-events-none absolute inset-x-0 bottom-0 h-1/3 bg-gradient-to-t from-navy-950/35 via-navy-950/5 to-transparent opacity-0 transition-opacity duration-500 group-hover:opacity-100" />
            </div>

            <div class="relative px-1 pt-5">
              <h3 class="font-display text-[15px] font-bold tracking-tight text-navy-900">
                {product.title}
              </h3>
              <p class="mt-2 text-sm leading-relaxed text-steel-600">
                {product.description}
              </p>
              <span class="mt-4 block h-px w-8 bg-gold-500 transition-all duration-500 group-hover:w-20" />
            </div>
          </article>
        ))
      }
    </div>

    <div class="reveal mt-12 flex flex-wrap justify-center gap-4">
      <a
        href={site.partner.url}
        target="_blank"
        rel="noopener noreferrer"
        class="btn-primary"
      >
        Visit Style by Global
        <Icon name="external" class="h-4 w-4" />
      </a>
      <a href="#contact" class="btn-secondary">
        Request a quote
        <Icon name="arrowRight" class="h-4 w-4" />
      </a>
    </div>
  </div>
</section>
