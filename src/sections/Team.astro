---
import { team } from '@data/site';

function initials(name: string) {
  return name
    .split(' ')
    .map((w) => w[0])
    .slice(0, 2)
    .join('')
    .toUpperCase();
}
---

<section id="team" class="section bg-navy-50/40">
  <div class="container-x">
    <div class="reveal mx-auto max-w-3xl text-center">
      <p class="eyebrow justify-center">Leadership</p>
      <h2 class="heading-section mt-4 text-balance">
        The people behind every project.
      </h2>
    </div>

    <div class="mt-14 grid justify-center gap-8 sm:grid-cols-2 lg:max-w-3xl lg:mx-auto reveal">
      {
        team.map((member, i) => (
          <article
            class="group relative rounded-2xl bg-white/70 ring-1 ring-navy-900/5 px-6 pb-7 pt-10 transition-all duration-500 hover:ring-navy-900/10"
            style={`transition-delay: ${i * 60}ms`}
          >
            <div class="flex justify-center">
              <div class="relative w-44 h-44 overflow-hidden rounded-full bg-navy-gradient ring-1 ring-navy-900/10 transition-all duration-500 group-hover:ring-navy-900/20">
                <span class="absolute inset-0 flex items-center justify-center font-display text-5xl font-bold text-white/30">
                  {initials(member.name)}
                </span>
                <img
                  src={member.image}
                  alt={member.name}
                  loading="lazy"
                  class="relative h-full w-full object-cover object-top scale-110 transition-transform duration-[900ms] ease-out group-hover:scale-[1.08]"
                />
              </div>
            </div>
            <div class="relative pt-5 text-center">
              <h3 class="font-display text-lg font-bold tracking-tight text-navy-900">
                {member.name}
              </h3>
              <p class="mt-1 text-sm font-semibold uppercase tracking-[0.15em] text-gold-500">
                {member.role}
              </p>
              <p class="mt-3 text-sm leading-relaxed text-steel-600">
                {member.bio}
              </p>
              <span class="mx-auto mt-4 block h-px w-8 bg-gold-500 transition-all duration-500 group-hover:w-20" />
            </div>
          </article>
        ))
      }
    </div>
  </div>
</section>
