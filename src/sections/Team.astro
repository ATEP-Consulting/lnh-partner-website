---
import { team } from '@data/site';

function initials(name: string) {
  return name
    .split(' ')
    .map((w) => w[0])
    .slice(0, 2)
    .join('')
    .toUpperCase();
}
---

<section id="team" class="section bg-navy-50/40">
  <div class="container-x">
    <div class="reveal mx-auto max-w-3xl text-center">
      <p class="eyebrow justify-center">Leadership</p>
      <h2 class="heading-section mt-4 text-balance">
        The people behind every project.
      </h2>
    </div>

    <div class="mt-14 grid justify-center gap-8 sm:grid-cols-2 lg:max-w-4xl lg:mx-auto reveal">
      {
        team.map((member) => (
          <article class="group overflow-hidden rounded-2xl bg-white shadow-card transition-all duration-500 hover:-translate-y-1 hover:shadow-card-hover">
            <div class="relative aspect-square overflow-hidden bg-navy-gradient">
              {/* Placeholder initials shown if the image fails to load */}
              <span class="absolute inset-0 flex items-center justify-center font-display text-6xl font-bold text-white/30">
                {initials(member.name)}
              </span>
              <img
                src={member.image}
                alt={member.name}
                loading="lazy"
                class="relative h-full w-full object-cover transition-transform duration-700 group-hover:scale-105"
              />
            </div>
            <div class="p-7">
              <h3 class="font-display text-xl font-bold tracking-tight">
                {member.name}
              </h3>
              <p class="mt-1 text-sm font-semibold uppercase tracking-[0.15em] text-gold-500">
                {member.role}
              </p>
              <p class="mt-4 text-sm leading-relaxed text-steel-600">
                {member.bio}
              </p>
            </div>
          </article>
        ))
      }
    </div>
  </div>
</section>
