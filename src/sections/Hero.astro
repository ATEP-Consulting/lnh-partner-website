---
import Icon from '@components/Icon.astro';
import { imageSrc } from '@lib/sanity';

type Props = { block: any };
const { block } = Astro.props;

const bgUrl = block?.backgroundImage
  ? imageSrc(block.backgroundImage, 2400)
  : 'https://images.unsplash.com/photo-1541888946425-d81bb19240f5?auto=format&fit=crop&w=2400&q=80';
---

<section
  id="home"
  class="relative isolate flex min-h-screen items-center overflow-hidden bg-navy-950 text-white"
>
  <!-- Background image -->
  <div class="absolute inset-0 -z-10">
    <img
      src={bgUrl}
      alt=""
      class="h-full w-full animate-slow-zoom object-cover"
      loading="eager"
      fetchpriority="high"
    />
    <div class="absolute inset-0 bg-gradient-to-r from-navy-950/95 via-navy-950/75 to-navy-950/40"></div>
    <div class="absolute inset-0 bg-radial-fade"></div>
  </div>

  <div class="container-x relative pt-32 pb-20">
    <div class="max-w-3xl">
      {block?.eyebrow && (
        <p class="eyebrow reveal animate-fade-in opacity-0" style="animation-delay: 0.1s; animation-fill-mode: forwards;">
          {block.eyebrow}
        </p>
      )}
      <h1
        class="heading-display mt-6 text-balance animate-fade-up opacity-0"
        style="animation-delay: 0.25s; animation-fill-mode: forwards;"
      >
        {block?.headingStart}
        {block?.headingAccent && (
          <>
            {' '}
            <span class="relative inline-block">
              <span class="bg-gold-gradient bg-[length:200%_auto] bg-clip-text text-transparent animate-shimmer">
                {block.headingAccent}
              </span>
            </span>
          </>
        )}
        {block?.headingEnd && <><br />{block.headingEnd}</>}
      </h1>
      {block?.lead && (
        <p
          class="lead mt-7 max-w-2xl text-white/75 animate-fade-up opacity-0"
          style="animation-delay: 0.45s; animation-fill-mode: forwards;"
        >
          {block.lead}
        </p>
      )}

      <div
        class="mt-10 flex flex-wrap gap-4 animate-fade-up opacity-0"
        style="animation-delay: 0.6s; animation-fill-mode: forwards;"
      >
        {block?.primaryCtaLabel && (
          <a href={block.primaryCtaHref || '#contact'} class="btn-primary">
            {block.primaryCtaLabel}
            <Icon name="arrowRight" class="h-4 w-4" />
          </a>
        )}
        {block?.secondaryCtaLabel && (
          <a href={block.secondaryCtaHref || '#projects'} class="btn-ghost-light">
            {block.secondaryCtaLabel}
          </a>
        )}
      </div>
    </div>

    {block?.stats?.length > 0 && (
      <dl class="mt-20 grid grid-cols-2 gap-x-8 gap-y-10 border-t border-white/10 pt-12 sm:grid-cols-4 reveal">
        {block.stats.map((s: any) => (
          <div>
            <dt class="text-xs font-semibold uppercase tracking-[0.18em] text-gold-400">
              {s.label}
            </dt>
            <dd class="mt-2 font-display text-3xl font-bold tracking-tight md:text-4xl">
              {s.value}
            </dd>
          </div>
        ))}
      </dl>
    )}
  </div>

  <a
    href="#services"
    class="absolute bottom-8 left-1/2 hidden -translate-x-1/2 text-white/60 transition-colors hover:text-white md:block"
    aria-label="Scroll to services"
  >
    <svg viewBox="0 0 24 24" class="h-8 w-8 animate-bounce" fill="none" stroke="currentColor" stroke-width="1.5">
      <path d="M12 5v14M5 12l7 7 7-7" stroke-linecap="round" stroke-linejoin="round" />
    </svg>
  </a>
</section>
