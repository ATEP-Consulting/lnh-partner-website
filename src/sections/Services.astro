---
import Icon from '@components/Icon.astro';
import { services } from '@data/site';
---

<section id="services" class="section bg-white">
  <div class="container-x">
    <div class="reveal mx-auto max-w-3xl text-center">
      <p class="eyebrow justify-center">What we do</p>
      <h2 class="heading-section mt-4 text-balance">
        Eight specialties.
        <span class="text-gold-500">One accountable partner.</span>
      </h2>
      <p class="lead mt-6 text-balance">
        We deliver every stage of a project under one roof — from earthworks to
        finishing carpentry — so you only ever speak to one team.
      </p>
    </div>

    <div class="mt-16 grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
      {
        services.map((service, i) => (
          <article
            class="card reveal group"
            style={`transition-delay: ${i * 60}ms`}
          >
            <div class="mb-6 inline-flex h-12 w-12 items-center justify-center rounded-lg bg-navy-50 text-navy-800 transition-colors duration-300 group-hover:bg-gold-500 group-hover:text-navy-950">
              <Icon name={service.icon} class="h-6 w-6" />
            </div>
            <h3 class="font-display text-lg font-bold tracking-tight">
              {service.title}
            </h3>
            <p class="mt-3 text-sm leading-relaxed text-steel-600">
              {service.description}
            </p>
            <div class="mt-6 inline-flex items-center text-xs font-semibold uppercase tracking-[0.15em] text-gold-500 opacity-0 transition-all duration-300 group-hover:opacity-100">
              Learn more
              <Icon name="arrowRight" class="ml-2 h-3.5 w-3.5" />
            </div>
          </article>
        ))
      }
    </div>
  </div>
</section>
