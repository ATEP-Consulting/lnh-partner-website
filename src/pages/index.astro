---
import Layout from '@layouts/Layout.astro';
import Hero from '@sections/Hero.astro';
import Services from '@sections/Services.astro';
import About from '@sections/About.astro';
import Why from '@sections/Why.astro';
import Projects from '@sections/Projects.astro';
import Pergolas from '@sections/Pergolas.astro';
import Gallery from '@sections/Gallery.astro';
import Partner from '@sections/Partner.astro';
import Team from '@sections/Team.astro';
import Testimonials from '@sections/Testimonials.astro';
import Contact from '@sections/Contact.astro';
import { getHomePage, getSiteConfig } from '@lib/queries';

const [siteConfig, homePage] = await Promise.all([
  getSiteConfig(),
  getHomePage(),
]);

const sections = (homePage?.sections ?? []).filter(
  (s: any) => s.visible !== false,
);

// Extract services list from the services section to feed the Footer + Contact
const servicesBlock = sections.find((s: any) => s._type === 'servicesBlock');
const services = servicesBlock?.services ?? [];
---

<Layout siteConfig={siteConfig} services={services}>
  {sections.map((block: any) => {
    switch (block._type) {
      case 'heroBlock': return <Hero block={block} />;
      case 'servicesBlock': return <Services block={block} />;
      case 'aboutBlock': return <About block={block} />;
      case 'whyBlock': return <Why block={block} />;
      case 'projectsBlock': return <Projects block={block} />;
      case 'pergolasBlock': return <Pergolas block={block} />;
      case 'galleryBlock': return <Gallery block={block} />;
      case 'partnerBlock': return <Partner block={block} />;
      case 'teamBlock': return <Team block={block} />;
      case 'testimonialsBlock': return <Testimonials block={block} />;
      case 'contactBlock': return <Contact block={block} siteConfig={siteConfig} services={services} />;
      default: return null;
    }
  })}
</Layout>
