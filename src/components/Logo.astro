---
type Props = {
  variant?: 'light' | 'dark';
  class?: string;
};

const { variant = 'dark', class: className = '' } = Astro.props as Props;

const wrapper = 'bg-transparent';
---

<a
  href="/"
  class={`group inline-flex items-center ${className}`}
  aria-label="LNH & Partner — home"
>
  <span
    class={`inline-flex items-center justify-center rounded-md transition-transform duration-300 group-hover:scale-[1.02] ${wrapper}`}
  >
    <img
      src="/assets/images/logo.png"
      alt="LNH & Partner"
      width="54"
      height="40"
      class="h-9 w-auto select-none md:h-10"
      loading="eager"
      decoding="async"
    />
  </span>
</a>
