---
type Props = {
  variant?: 'light' | 'dark';
  class?: string;
};

const { variant = 'dark', class: className = '' } = Astro.props as Props;

const wordmark = variant === 'light' ? 'text-white' : 'text-navy-900';
const ampersand = variant === 'light' ? 'text-gold-400' : 'text-gold-500';
const sub = variant === 'light' ? 'text-white/60' : 'text-steel-500';
---

<a href="/" class={`group inline-flex items-center gap-3 ${className}`} aria-label="LNH & Partner home">
  <span class="relative inline-flex h-11 w-11 items-center justify-center rounded-md bg-navy-gradient text-white shadow-md ring-1 ring-white/10">
    <span class="font-display text-lg font-bold tracking-tight">LNH</span>
    <span class="absolute -bottom-1 -right-1 h-2 w-2 rounded-full bg-gold-500 ring-2 ring-white"></span>
  </span>
  <span class="leading-tight">
    <span class={`block font-display text-lg font-bold tracking-tight ${wordmark}`}>
      LNH <span class={ampersand}>&</span> Partner
    </span>
    <span class={`block text-[10px] font-semibold uppercase tracking-[0.25em] ${sub}`}>
      Construction · Real Estate
    </span>
  </span>
</a>
