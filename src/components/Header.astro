---
import Logo from './Logo.astro';
import Icon from './Icon.astro';
import { navLinks } from '@data/site';
---

<header
  id="site-header"
  class="fixed inset-x-0 top-0 z-[60] transition-all duration-500"
  data-state="top"
>
  <div class="container-x flex items-center justify-between py-4">
    <Logo variant="light" class="header-logo-light" />
    <Logo variant="dark" class="header-logo-dark hidden" />

    <nav class="hidden lg:block" aria-label="Primary">
      <ul class="flex items-center gap-7 text-sm font-medium">
        {
          navLinks.map((link) => (
            <li>
              <a
                href={link.href}
                class="header-nav-link relative text-white/85 transition-colors hover:text-white"
              >
                {link.label}
              </a>
            </li>
          ))
        }
      </ul>
    </nav>

    <div class="hidden items-center gap-4 lg:flex">
      <a href="#contact" class="btn btn-primary !py-2.5">
        Get a Quote
        <Icon name="arrowRight" class="h-4 w-4" />
      </a>
    </div>

    <button
      id="mobile-menu-toggle"
      class="header-burger relative inline-flex h-11 w-11 items-center justify-center rounded-md text-white transition-colors lg:hidden"
      aria-label="Open menu"
      aria-controls="mobile-menu"
      aria-expanded="false"
    >
      <Icon name="menu" class="h-6 w-6" />
    </button>
  </div>

</header>

<!-- Mobile menu (outside header to avoid backdrop-filter containing block) -->
<div
  id="mobile-menu"
  class="pointer-events-none fixed inset-0 z-50 bg-navy-950/95 opacity-0 backdrop-blur-md transition-opacity duration-300 lg:hidden"
  aria-hidden="true"
>
  <div class="container-x flex h-full flex-col pt-28 pb-12">
    <nav aria-label="Mobile">
      <ul class="space-y-4 text-2xl font-display font-semibold text-white">
        {
          navLinks.map((link) => (
            <li>
              <a
                href={link.href}
                class="mobile-nav-link block border-b border-white/10 py-3 transition-colors hover:text-gold-400"
              >
                {link.label}
              </a>
            </li>
          ))
        }
      </ul>
    </nav>
    <div class="mt-auto">
      <a href="#contact" class="btn btn-primary mobile-nav-link w-full">
        Get a Quote
        <Icon name="arrowRight" class="h-4 w-4" />
      </a>
    </div>
  </div>
</div>

<script>
  const header = document.getElementById('site-header');
  const burger = document.getElementById('mobile-menu-toggle');
  const menu = document.getElementById('mobile-menu');
  const lightLogo = header?.querySelector('.header-logo-light');
  const darkLogo = header?.querySelector('.header-logo-dark');
  const navLinks = header?.querySelectorAll('.header-nav-link');
  const mobileLinks = menu?.querySelectorAll('.mobile-nav-link');

  let menuOpen = false;

  function applyScrolledStyles(scrolled: boolean) {
    if (!header) return;
    if (scrolled) {
      header.classList.add(
        'bg-white',
        'shadow-md',
        'shadow-navy-900/5',
        'backdrop-blur-md',
      );
      header.dataset.state = 'scrolled';
      lightLogo?.classList.add('hidden');
      darkLogo?.classList.remove('hidden');
      navLinks?.forEach((l) => {
        l.classList.remove('text-white/85', 'hover:text-white');
        l.classList.add('text-navy-700', 'hover:text-navy-900');
      });
      burger?.classList.remove('text-white');
      burger?.classList.add('text-navy-900');
    } else {
      header.classList.remove(
        'bg-white',
        'shadow-md',
        'shadow-navy-900/5',
        'backdrop-blur-md',
      );
      header.dataset.state = 'top';
      lightLogo?.classList.remove('hidden');
      darkLogo?.classList.add('hidden');
      navLinks?.forEach((l) => {
        l.classList.add('text-white/85', 'hover:text-white');
        l.classList.remove('text-navy-700', 'hover:text-navy-900');
      });
      burger?.classList.add('text-white');
      burger?.classList.remove('text-navy-900');
    }
  }

  function onScroll() {
    if (menuOpen) return;
    applyScrolledStyles(window.scrollY > 12);
  }

  window.addEventListener('scroll', onScroll, { passive: true });
  onScroll();

  function setMenu(open: boolean) {
    menuOpen = open;
    if (!menu || !burger) return;
    menu.classList.toggle('opacity-100', open);
    menu.classList.toggle('opacity-0', !open);
    menu.classList.toggle('pointer-events-auto', open);
    menu.classList.toggle('pointer-events-none', !open);
    burger.setAttribute('aria-expanded', String(open));
    document.body.style.overflow = open ? 'hidden' : '';
    if (open) {
      header?.classList.add('!bg-transparent', '!shadow-none', '!backdrop-blur-none');
      burger?.classList.remove('text-navy-900');
      burger?.classList.add('text-white');
      lightLogo?.classList.remove('hidden');
      darkLogo?.classList.add('hidden');
    } else {
      header?.classList.remove('!bg-transparent', '!shadow-none', '!backdrop-blur-none');
      applyScrolledStyles(window.scrollY > 12);
    }
  }

  burger?.addEventListener('click', () => setMenu(!menuOpen));
  mobileLinks?.forEach((l) => l.addEventListener('click', () => setMenu(false)));
</script>
